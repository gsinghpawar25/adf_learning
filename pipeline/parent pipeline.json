					"body": {
						"value": "{\n  \"pipeline_name\":\"@{pipeline().Pipeline}\",\n  \"run_id\":\"@{pipeline().RunId}\",\n  \"status\":\"@{activity('Execute Pipeline SQL to ADLS').Status}\",\n  \"error\" : \"@{if(equals(activity('Execute Pipeline SQL to ADLS').Status, 'Failed'), string(activity('Execute Pipeline SQL to ADLS').error), 'No error')}\"\n}\n\n",
						"type": "Expression"
					}
				}
			}
		],
		"parameters": {
			"files": {
				"type": "array",
				"defaultValue": [
