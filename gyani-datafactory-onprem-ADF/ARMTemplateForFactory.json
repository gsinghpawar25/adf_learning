							"method": "GET",
							"headers": {},
							"url": "https://raw.githubusercontent.com/anshlambagit/AnshLambaYoutube/refs/heads/main/ADF_Project/DimAirport.json"
						}
					},
					{
						"name": "Copy data from git to adls",
						"type": "Copy",
						"dependsOn": [
							{
								"activity": "fetch data from webAPI",
								"dependencyConditions": [
									"Succeeded"
								]
