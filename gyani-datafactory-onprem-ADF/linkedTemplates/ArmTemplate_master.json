{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "gyani-datafactory-onprem-ADF"
		},
		"ls_datalake_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'ls_datalake'"
		},
		"ls_onprem_file_connection_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'ls_onprem_file_connection'"
		},
		"ls_sqlsource_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'ls_sqlsource'"
		},
		"ls_datalake_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://onpremadfproject.dfs.core.windows.net/"
		},
		"ls_githubRaw_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://raw.githubusercontent.com/"
		},
		"ls_onprem_file_connection_properties_typeProperties_host": {
			"type": "string",
			"defaultValue": "C:\\adfonpremproject"
		},
		"ls_onprem_file_connection_properties_typeProperties_userId": {
			"type": "string",
			"defaultValue": "singhpawargyanendra@outlook.com"
		},
		"ls_sqlsource_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "adf-onprem-server.database.windows.net"
		},
		"ls_sqlsource_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "adf-onprem"
		},
		"ls_sqlsource_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "gsinghpawar25"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "gyani-datafactory-onprem-ADF_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"ls_datalake_accountKey": {
						"value": "[parameters('ls_datalake_accountKey')]"
					},
					"ls_sqlsource_password": {
						"value": "[parameters('ls_sqlsource_password')]"
					},
					"ls_onprem_file_connection_password": {
						"value": "[parameters('ls_onprem_file_connection_password')]"
					},
					"ls_datalake_properties_typeProperties_url": {
						"value": "[parameters('ls_datalake_properties_typeProperties_url')]"
					},
					"ls_githubRaw_properties_typeProperties_url": {
						"value": "[parameters('ls_githubRaw_properties_typeProperties_url')]"
					},
					"ls_sqlsource_properties_typeProperties_server": {
						"value": "[parameters('ls_sqlsource_properties_typeProperties_server')]"
					},
					"ls_sqlsource_properties_typeProperties_database": {
						"value": "[parameters('ls_sqlsource_properties_typeProperties_database')]"
					},
					"ls_sqlsource_properties_typeProperties_userName": {
						"value": "[parameters('ls_sqlsource_properties_typeProperties_userName')]"
					},
					"ls_onprem_file_connection_properties_typeProperties_host": {
						"value": "[parameters('ls_onprem_file_connection_properties_typeProperties_host')]"
					},
					"ls_onprem_file_connection_properties_typeProperties_userId": {
						"value": "[parameters('ls_onprem_file_connection_properties_typeProperties_userId')]"
					}
				}
			},
			"dependsOn": []
		},
		{
			"name": "gyani-datafactory-onprem-ADF_ArmTemplate_1",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_1.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					}
				}
			},
			"dependsOn": [
				"[resourceId('Microsoft.Resources/deployments', 'gyani-datafactory-onprem-ADF_ArmTemplate_0')]"
			]
		}
	]
}